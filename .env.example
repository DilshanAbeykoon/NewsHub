# Generate a strong random secret and paste it here.
# This protects /api/cron from unauthorized calls.
# Example: openssl rand -hex 32
CRON_SECRET=your-secret-here

# Optional: set this to your Vercel deployment URL to help the server-side
# page component call /api/feed correctly. Leave unset for local dev.
# NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
